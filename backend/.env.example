# Server
PORT=4000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Rate limiting (public endpoints: /health, /soroban/config)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Soroban / Stellar
SOROBAN_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Optional: contract id for the deployed Shelterflex contract
SOROBAN_CONTRACT_ID=

# Soroban contract IDs (set after deploying contracts)
SOROBAN_USDC_TOKEN_ID=
SOROBAN_STAKING_POOL_ID=
SOROBAN_STAKING_REWARDS_ID=
SOROBAN_TIMELOCK_ID=

# Secret key used to sign Soroban transactions (e.g., your operator identity)
SOROBAN_ADMIN_SECRET=

# USDC token contract address (required in non-development environments)
# Testnet example: USDC_TOKEN_ADDRESS=0x8d3e2a4e2c3b4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9
# Mainnet example: USDC_TOKEN_ADDRESS=0xa0b86a33e6c4c4c4c4c4c4c4c4c4c4c4c4c4c4c4c4c
USDC_TOKEN_ADDRESS=

# Custodial wallet master keys (envelope encryption KEKs)
# REQUIRED for production: Base64-encoded 32-byte AES-256 key for encrypting wallet secret keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# SECURITY: Never commit actual keys to git. This is used for AES-256-GCM encryption at rest.
CUSTODIAL_WALLET_MASTER_KEY_V1=
CUSTODIAL_WALLET_MASTER_KEY_V2=
# Active version for new wallets and rotation target (1 or 2)
CUSTODIAL_WALLET_MASTER_KEY_ACTIVE_VERSION=1

# Custodial mode configuration
CUSTODIAL_MODE_ENABLED=true
CUSTODIAL_SIGNING_PAUSED=false

# Indexer configuration
INDEXER_POLL_MS=5000
INDEXER_START_LEDGER=


DATABASE_URL=postgres://app:app@localhost:5432/app
ENCRYPTION_KEY=supersecretkey123

# NGN → USDC conversion (deposits / staking on-ramp)
FX_RATE_NGN_PER_USDC=1600
# stub | http | fallback
CONVERSION_PROVIDER=stub
CONVERSION_RATE_URL=
CONVERSION_RATE_API_KEY=
CONVERSION_HTTP_TIMEOUT_MS=10000
CONVERSION_RATE_MIN=1
CONVERSION_RATE_MAX=50000

# Secret Rotation Configuration
# Secrets are automatically hot-reloaded when environment variables change
# Grace period allows old secrets to remain valid during rotation
# Default grace period: 5 minutes for most secrets, 15 minutes for encryption keys
# Audit logs are written to ./logs/secret-rotation-audit.log
AUDIT_LOG_DIR=./logs

# OTP Delivery (Resend)
# REQUIRED when OTP_DELIVERY_PROVIDER=email
OTP_DELIVERY_PROVIDER=console
RESEND_API_KEY=
RESEND_FROM_EMAIL=otp@yourdomain.com

# Metrics & Monitoring
# Prometheus exporter port for metrics scraping
PROMETHEUS_PORT=9464

# OpenTelemetry configuration
OTEL_SERVICE_NAME=shelterflex-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SAMPLING_RATIO=1.0
# Optional: Custom headers for OTLP exporter (format: key=value,key2=value2)
OTEL_EXPORTER_OTLP_HEADERS=
