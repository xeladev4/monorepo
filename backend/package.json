{
  "name": "shelterflex-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:backup": "tsx src/scripts/backup.ts",
    "db:restore": "tsx src/scripts/restore.ts",
    "openapi:validate": "redocly lint docs/openapi.yml",
    "openapi:preview": "redocly preview-docs docs/openapi.yml",
    "test": "vitest run",
    "test:ci": "vitest run --exclude 'src/soroban/**/*.test.ts' --exclude 'src/routes/webhooks.test.ts' --exclude 'src/routes/wallet.test.ts' --exclude 'src/routes/stakingPositionReal.test.ts' --exclude 'src/routes/stakingQuote.test.ts' --exclude 'src/routes/session.test.ts' --exclude 'src/routes/ngnWallet.test.ts' --exclude 'src/routes/criticalFlows.e2e.test.ts'",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run src/routes/criticalFlows.e2e.test.ts",
    "test:integration": "SOROBAN_INTEGRATION_TESTS=true vitest run src/soroban/real-adapter.integration.test.ts",
    "test:integration:watch": "SOROBAN_INTEGRATION_TESTS=true vitest src/soroban/real-adapter.integration.test.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation-express": "^0.62.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/instrumentation-pg": "^0.66.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@stellar/stellar-sdk": "^14.6.1",
    "@types/lru-cache": "^7.10.9",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.2.7",
    "morgan": "^1.10.0",
    "pg": "^8.19.0",
    "prom-client": "^15.1.3",
    "resend": "^6.9.4",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@redocly/cli": "^1.34.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/urijs": "^1.19.26",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "fast-check": "^4.5.3",
    "pg-mem": "^3.0.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
